{
  "expo": {
    "name": "MatchMaker",
    "slug": "matchmakerapp",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "matchmaker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "MatchMaker хоче додати нагадування про профілі до вашого календаря",
        "NSPhotoLibraryUsageDescription": "MatchMaker хоче прикріпити фото до профілів",
        "NSPhotoLibraryAddUsageDescription": "MatchMaker хоче зберегти фото"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.matchmaker.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "MatchMaker хоче прикріпити фото до профілів"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "MatchMaker хоче додавати нагадування до вашого календаря"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b3eec0b-861b-44a6-a8da-c69c9ba087ff"
      }
    }
  }
}
